      const hasProgress = summary.status !== 'new';
      const isImported = test.source === 'imported';
      card.innerHTML = `<div class="card-title-row"><h2>${escapeHTML(test.title)}</h2><span class="status-badge ${summary.status === 'done' ? 'done' : summary.status === 'resume' ? 'resume' : ''}">${summary.status === 'done' ? 'Completed' : summary.status === 'resume' ? 'In progress' : 'New'}</span></div><div class="card-progress-row"><div class="card-progress" title="${summary.pct}% completed"><span style="width:${summary.pct}%"></span></div><span class="card-progress-text">${summary.pct}%</span></div><div class="card-meta"><div><strong>${questionText}</strong><span>Questions</span></div><div><strong>${summary.attempted}</strong><span>Done</span></div><div><strong>${summary.attempted ? summary.scorePct + '%' : '—'}</strong><span>Score</span></div></div><div class="card-actions"><button class="secondary-button" data-action="${hasProgress ? 'resume' : 'start'}" aria-label="${hasProgress ? 'Resume test' : 'Start test'}">${hasProgress ? 'Resume' : 'Start'}</button>${hasProgress ? '<button class="secondary-button" data-action="restart" aria-label="Restart test">Restart</button>' : ''}${isImported ? '<button class="danger-button" data-action="remove-import" aria-label="Remove file">Remove</button>' : ''}</div>`;